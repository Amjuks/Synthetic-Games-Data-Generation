# CUSTOM_MODEL=gpt-oss-120b
# CUSTOM_TEMPERATURE=0.1
# CUSTOM_MAX_TOKENS=800
# CUSTOM_REASONING=Low
# CUSTOM_ENABLE_THINKING=false
